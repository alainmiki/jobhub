{
  "name": "jobhub",
  "version": "1.0.0",
  "description": "Job & Internship Portal - Connect candidates with opportunities",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "./src/index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "cross-env NODE_ENV=production node ./src/index.js",
    "dev": "node --watch --watch-path=src ./src/index.js",
    "server": "npm run build && (start /b npm run css & npm run dev)",
    "css": "cross-env NODE_ENV=development postcss src/public/css/input.css -o src/public/css/output.css --watch",
    "build:tailwind": "cross-env NODE_ENV=production postcss src/public/css/input.css -o src/public/css/output.css --minify",
    "build": "npm run build:clean && npm run build:tailwind",
    "build:clean": "rimraf ./src/public/css/output.css"
  },
  "engines": {
    "node": ">=24.13.1"
  },
  "dependencies": {
    "@better-auth/mongo-adapter": "^1.5.6",
    "@better-auth/prisma-adapter": "^1.5.6",
    "better-auth": "^1.5.6",
    "chokidar": "^3.6.0",
    "cors": "^2.8.6",
    "csurf": "^1.11.0",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "mongoose": "^9.4.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "nunjucks": "^3.2.4",
    "validator": "^13.15.35",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.16",
    "daisyui": "^5.3.10",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-nested": "^7.0.2",
    "postcss-simple-vars": "^7.0.1",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "vitest": "^3.1.0",
    "@vitest/coverage-v8": "^3.1.0",
    "supertest": "^7.0.0",
    "jsdom": "^26.1.0"
  }
}
